{
  "description": "Rojo-based GitHub build for Zundamon's kItchen Roblox experience",
  "devDependencies": {
    "@johnnymorganz/stylua-bin": "2.5.2",
    "rojo": "1.0.3-rojo7.6.1"
  },
  "name": "zundamons-kitchen-roblox-build",
  "private": true,
  "scripts": {
    "lint": "npm run lint:stylua && npm run lint:selene",
    "lint:selene": "node scripts/lint-selene.mjs",
    "lint:stylua": "npx stylua-bin --check src",
    "rojo:build": "rojo build default.project.json -o workspace/Zundamons-kItchen.rbxl",
    "rojo:serve": "rojo serve default.project.json",
    "validate": "node scripts/validate-structure.mjs",
    "overnight": "node scripts/overnight-build.mjs",
    "overnight:ps": "powershell -File scripts/overnight.ps1",
    "generate-quests": "python scripts/agent_orchestrator/run.py --generate-quests 10",
    "deploy-models": "python scripts/agent_orchestrator/tools/model_deploy.py",
    "import:scan": "python scripts/agent_orchestrator/tools/batch_import.py --scan",
    "import:apply": "python scripts/agent_orchestrator/tools/batch_import.py --apply",
    "agent:task": "python scripts/agent_orchestrator/run.py",
    "fix:mesh": "powershell -File scripts/fix_mesh_ids.ps1"
  },
  "version": "0.2.0"
}
