{
  "better-comments.tags": [
    {
      "backgroundColor": "transparent",
      "color": "#FF6B6B",
      "strikethrough": false,
      "tag": "!"
    },
    {
      "backgroundColor": "transparent",
      "color": "#FFE66D",
      "strikethrough": false,
      "tag": "?"
    },
    {
      "backgroundColor": "transparent",
      "color": "#4ECDC4",
      "strikethrough": false,
      "tag": "//"
    },
    {
      "backgroundColor": "transparent",
      "color": "#A78BFA",
      "strikethrough": false,
      "tag": "todo"
    }
  ],
  "editor.formatOnSave": true,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "keyword.custom.Collectible",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#FF6B6B"
        }
      },
      {
        "scope": "keyword.custom.Inventory",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#4ECDC4"
        }
      },
      {
        "scope": "keyword.custom.RemoteEvent",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#FFE66D"
        }
      },
      {
        "scope": "keyword.custom.SaveData",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#A78BFA"
        }
      },
      {
        "scope": "keyword.custom.Harvest",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#34D399"
        }
      }
    ]
  },
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true
  },
  "luau-lsp.require.mode": "relative",
  "luau-lsp.sourcemap.enabled": true,
  "selene.enable": true,
  "stylua.targetReleaseVersion": "latest",
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "HACK",
    "NOTE",
    "PERF"
  ]
}
