{
  "name": "zundamons-kitchen-roblox-build",
  "private": true,
  "version": "0.3.0",
  "description": "Rojo-based GitHub build for Zundamon's kItchen Roblox experience",
  "scripts": {
    "validate": "node scripts/validate-structure.mjs && npm run security",
    "verify:safety": "node scripts/verify-publish-safety.mjs",
    "security": "node scripts/check-secrets.mjs && node scripts/check-git-hygiene.mjs && node scripts/check-remote-sync.mjs && node scripts/check-publish-readiness.mjs",
    "security:history": "node scripts/check-git-history.mjs",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:git": "node scripts/check-git-hygiene.mjs",
    "security:remotes": "node scripts/check-remote-sync.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "lint": "npm run lint:stylua && npm run lint:selene",
    "lint:stylua": "node scripts/lint-stylua.mjs",
    "lint:selene": "node scripts/lint-selene.mjs",
    "sourcemap": "node scripts/sourcemap.mjs",
    "rojo:build": "node scripts/rojo-build.mjs",
    "rojo:serve": "node scripts/rojo-serve.mjs",
    "rokit:install": "node scripts/install-rokit-ci.mjs"
  }
}
